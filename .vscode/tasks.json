{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start server",
      "type": "shell",
      "command": "npm start",  // 你可以根据自己的需求修改命令
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "This task runs the development server"
    },
    {
      "label": "run tests",
      "type": "shell",
      "command": "npm test",  // 修改为你自己项目的测试命令
      "group": {
        "kind": "test"
      },
      "problemMatcher": ["$eslint-stylish"],  // 可根据需要调整
      "detail": "This task runs the tests"
    }
  ]
}